{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist/main",
        "rootDir": "src/main",
        "resolveJsonModule": true,
        "declaration": true
    },
    "include": [
        "src/main/**/*"
    ]
}